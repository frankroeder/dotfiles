#!/usr/bin/env zsh
# definitions for all sessions and scripts

export DOTFILES=$HOME/.dotfiles
export OSTYPE=$(uname -s)
export ARCHITECTURE=$(uname -m)

if [[ "$TERM_PROGRAM" == "ghostty" ]]; then
    export TERM=xterm-256color
fi

path=(
  # path to linux and homebrew intel-based binaries
  /usr/local/{bin,sbin}
  # os/architecture-specific dotfile binaries
  $DOTFILES/bin/$OSTYPE/$ARCHITECTURE
  # os-specific dotfile binaries
  $DOTFILES/bin/$OSTYPE
  # user-specific binaries for linux
  $HOME/bin
  $HOME/.local/bin
  $path
)

[[ $ARCHITECTURE == 'arm64' || $ARCHITECTURE == 'aarch64' ]] && {
  path=(
    # homebrew arm-based binaries
    /opt/homebrew/{bin,sbin}
    $path
  )
}

# Zsh-specific environment variables (common ones are in shared/00-env.sh)
# Note: EDITOR, VISUAL, LESS, PAGER, MANPAGER, LANG, LC_ALL are set in shared/00-env.sh

if [[ "$OSTYPE" == "Darwin" ]]; then
  export BROWSER="open"
elif [[ "$OSTYPE" == "Linux" ]]; then
  if (( $+commands[librewolf] )); then
    export BROWSER="librewolf"
  elif (( $+commands[firefox] )); then
    export BROWSER="firefox"
  fi
  if [[ -z "${SSH_AUTH_SOCK:-}" ]] && [[ -n "${XDG_RUNTIME_DIR:-}" ]] && [[ -S "${XDG_RUNTIME_DIR}/ssh-agent.socket" ]]; then
    export SSH_AUTH_SOCK="${XDG_RUNTIME_DIR}/ssh-agent.socket"
  fi
  export TERM=xterm-256color
fi

# name of the browser application for various scripts
if [[ "$OSTYPE" == "Darwin" ]] && [[ -o interactive ]] && [[ -z "${BROWSER_NAME:-}" ]]; then
  browser_name="$("$DOTFILES/bin/Darwin/browser" name 2>/dev/null || true)"
  [[ -n "$browser_name" ]] && export BROWSER_NAME="$browser_name"
  unset browser_name
fi

export GPG_TTY=$(tty)

if [ -r "$HOME/.cargo/env" ]; then
  source "$HOME/.cargo/env"
fi
