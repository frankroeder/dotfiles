#!/usr/bin/env sh

[user]
  name = Frank Roeder
  useConfigOnly = true
	email = fr.coding@proton.me
	nam = Frank Röder

[github]
  user = frankroeder

[status]
  showUntrackedFiles = all

[merge]
	tool = nvimdiff

[mergetool]
	keepBackup = false
	prompt = false

[mergetool "nvimdiff"]
	cmd = nvim -d \"$BASE\" \"$LOCAL\" \"$REMOTE\" \"$MERGED\" -c '$wincmd w' -c 'wincmd J'

[diff]
  tool = vimdiff
  renames = copies

[pull]
  rebase = true

[push]
  followTags = true
  default = simple

[core]
  autocrlf = false
  filemode = false
  whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
  excludesfile = ~/.gitignore
  pager = less -XFR
  ignorecase = false
  attributesfile = ~/.dotfiles/git/gitattributes

[commit]
  verbose = false
  template = ~/.dotfiles/git/gitmessage
  gpgsign = false

[color]
  ui = true
  branch = auto
  diff = auto
  status = auto

[init]
  defaultBranch = main

[submodule]
	recurse = true

[include]
  path = "~/.local.gitconfig"
