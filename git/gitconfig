#!/usr/bin/env sh

[user]
  name = Frank Roeder
  useConfigOnly = true
	email = fr.coding@proton.me
	nam = Frank Röder

[github]
  user = frankroeder

[status]
  showUntrackedFiles = all

[merge]
	tool = nvimdiff

[mergetool]
	keepBackup = false
	prompt = false

[mergetool "nvimdiff"]
	cmd = nvim -d \"$BASE\" \"$LOCAL\" \"$REMOTE\" \"$MERGED\" -c '$wincmd w' -c 'wincmd J'

[diff]
  tool = vimdiff
  renames = copies

[pull]
  rebase = true

[push]
  followTags = true
  default = simple

[core]
  autocrlf = false
  filemode = false
  whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
  excludesfile = ~/.gitignore
  pager = less -XFR
  ignorecase = false
  attributesfile = ~/.dotfiles/git/gitattributes

[commit]
  verbose = false
  template = ~/.dotfiles/git/gitmessage
  gpgsign = false

[color]
  ui = true
  branch = auto
  diff = auto
  status = auto

[color "diff"]
  frag = 12 bold
  meta = 8
  new = 10
  old = 9
  newMoved = 14
  oldMoved = 12

[color "branch"]
  current = 12 bold
  local = 12
  remote = 14

[color "status"]
  header = 8
  added = 10
  changed = 12
  untracked = 9
  branch = 12 bold
  nobranch = 9 bold
  localBranch = 12 bold
  remoteBranch = 14
  upstream = 8

[color "grep"]
  match = black 12
  filename = 12
  function = 14
  linenumber = 8

[init]
  defaultBranch = main

[submodule]
	recurse = true

[include]
  path = "~/.local.gitconfig"
