#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
urls="$("$script_dir/browser" urls)"
selected="$(printf '%s\n' "$urls" | awk 'NF' | fzf --exit-0 --multi)"

if [[ -n "$selected" ]]; then
  printf '%s' "$selected" | pbcopy
  echo "Copied selected URLs to clipboard."
fi
