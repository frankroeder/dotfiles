#!/bin/bash
# Catppuccin Mocha/Latte borders, synced with sketchybar/colors.lua (auto dark/light like nvim/ghostty)
# edit palettes in colors.lua or here for global align

is_dark=1
if [ "$(uname -s)" = "Darwin" ]; then
  style=$(defaults read -g AppleInterfaceStyle 2>/dev/null || echo Light)
  case "$style" in
    *[Dd]ark*) is_dark=1 ;;
    *) is_dark=0 ;;
  esac
else
  # linux gsettings etc
  style=$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null || echo "")
  case "$style" in
    *dark*|*prefer-dark*) is_dark=1 ;;
    *) is_dark=0 ;;
  esac
fi

if [ "$is_dark" = "1" ]; then
  active="0xff89b4fa"      # cat blue (or change to b4befe lavender)
  inactive="0x55313244"    # surface0 ~33% alpha
else
  active="0xff1e66f5"      # latte blue
  inactive="0x55ccd0da"    # surface0 light ~33%
fi

exec borders active_color="$active" \
             inactive_color="$inactive" \
             width=8.0 \
             style=round \
             hidpi=on
