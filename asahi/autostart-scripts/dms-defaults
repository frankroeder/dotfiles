#!/usr/bin/env bash

set -euo pipefail

command -v dms >/dev/null 2>&1 || exit 0

for _ in {1..40}; do
  result="$(dms ipc call outputs setProfile Default 2>/dev/null || true)"
  if [ "$result" = "PROFILE_SET_SUCCESS: Default" ]; then
    break
  fi
  sleep 0.5
done

dms ipc call audio setvolume 5 || true
