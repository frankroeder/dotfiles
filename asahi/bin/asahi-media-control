#!/usr/bin/env bash

set -euo pipefail

target="${1:-}"
action="${2:-}"

if [ -z "$target" ] || [ -z "$action" ]; then
  echo "usage: $0 <output-volume|input-volume|brightness|keyboard-brightness|caps-lock|playerctl> <action>" >&2
  exit 2
fi

display_device() {
  local device="${ASAHI_BACKLIGHT_DEVICE:-apple-panel-bl}"

  if brightnessctl --device="$device" info >/dev/null 2>&1; then
    printf "%s\n" "$device"
    return 0
  fi

  for path in /sys/class/backlight/*; do
    [ -e "$path" ] || continue
    basename "$path"
    return 0
  done

  return 1
}

keyboard_device() {
  local device="${ASAHI_KEYBOARD_BACKLIGHT_DEVICE:-kbd_backlight}"

  if brightnessctl --device="$device" info >/dev/null 2>&1; then
    printf "%s\n" "$device"
    return 0
  fi

  for path in /sys/class/leds/*kbd_backlight*; do
    [ -e "$path" ] || continue
    basename "$path"
    return 0
  done

  return 1
}

brightness_step() {
  case "$1" in
    raise) printf "+5%%\n" ;;
    lower) printf "5%%-\n" ;;
    +1) printf "+1%%\n" ;;
    -1) printf "1%%-\n" ;;
    *)
      echo "unsupported brightness action: $1" >&2
      exit 2
      ;;
  esac
}

show_osd() {
  local function="$1"

  qs -c remix ipc call osd "$function" >/dev/null 2>&1 || true
}

case "$target" in
  output-volume)
    case "$action" in
      raise) wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+ ;;
      lower) wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%- ;;
      mute-toggle) wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle ;;
      +1) wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 1%+ ;;
      -1) wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 1%- ;;
    esac
    show_osd volume
    ;;
  input-volume)
    if [ "$action" = "mute-toggle" ]; then
      wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
      show_osd mic
      exit 0
    fi

    case "$action" in
      raise) wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%+ ;;
      lower) wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%- ;;
      +1) wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 1%+ ;;
      -1) wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 1%- ;;
    esac
    show_osd mic
    ;;
  playerctl)
    exec playerctl "$action"
    ;;
  brightness)
    device="$(display_device)"
    brightnessctl --quiet --device="$device" set "$(brightness_step "$action")"

    show_osd brightness
    ;;
  keyboard-brightness)
    device="$(keyboard_device)"
    brightnessctl --quiet --device="$device" set "$(brightness_step "$action")"

    show_osd keyboard
    ;;
  caps-lock)
    show_osd caps
    ;;
  *)
    echo "unknown target: $target" >&2
    exit 2
    ;;
esac
