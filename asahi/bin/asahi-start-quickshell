#!/usr/bin/env bash

set -u

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/quickshell"
log="$state_dir/asahi-start.log"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/quickshell"
modules=(
  remix
  screensaver
  expose
)

mkdir -p "$state_dir"
: > "$log"

for module in "${modules[@]}"; do
  [ -f "$config_dir/$module/shell.qml" ] || continue
  qs -n -d -c "$module" >>"$log" 2>&1
done
