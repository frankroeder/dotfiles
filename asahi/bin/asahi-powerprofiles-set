#!/usr/bin/env bash

set -euo pipefail

profile="${1:-}"

if [ -z "$profile" ]; then
  echo "usage: $0 <profile>" >&2
  exit 2
fi

if command -v powerprofilesctl >/dev/null 2>&1; then
  exec powerprofilesctl set "$profile"
fi

notify-send "Power profile" "powerprofilesctl is not installed. Install power-profiles-daemon."
exit 1

