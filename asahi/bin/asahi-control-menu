#!/usr/bin/env bash

set -euo pipefail

fuzzel_cmd="fuzzel --dmenu"

pick() {
  $fuzzel_cmd --placeholder "$1" || true
}

confirm() {
  local action="$1"
  local choice

  choice="$(printf '%s\n' "No" "Yes, $action" | pick "$action?")"
  [ "$choice" = "Yes, $action" ]
}

choice="$(printf '%s\n' "Lock" "Suspend" "Reboot" "Shutdown" | pick System)"

case "$choice" in
  Lock)
    loginctl lock-session
    ;;
  Suspend)
    loginctl lock-session
    systemctl suspend  # s2idle only (Asahi: no hibernation/disk support)
    ;;
  Reboot)
    confirm Reboot && systemctl reboot
    ;;
  Shutdown)
    confirm Shutdown && systemctl poweroff
    ;;
esac
