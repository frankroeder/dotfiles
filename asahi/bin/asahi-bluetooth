#!/usr/bin/env bash
set -euo pipefail

# JSON {text, tooltip, class, percentage}

powered=$(bluetoothctl show 2>/dev/null | awk -F': ' '/Powered:/ {print $2}' | head -1 || echo "no")

if [ "$powered" != "yes" ]; then
  jq -cn \
    --arg text "󰂲" \
    --arg tooltip "Bluetooth off" \
    --arg class "off" \
    --argjson percentage 0 \
    '{text:$text, tooltip:$tooltip, class:$class, percentage:$percentage}'
  exit 0
fi

alias=$(bluetoothctl show 2>/dev/null | awk -F': ' '/Alias:/ {print $2; exit}' || echo "Bluetooth")
num=$(bluetoothctl devices Connected 2>/dev/null | wc -l || echo 0)

tooltip="$alias"
if [ "$num" -gt 0 ]; then
  tooltip+=$'\n'"$num connected"
  # list a few
  while read -r _ mac name; do
    [ -z "$mac" ] && continue
    bat=$(bluetoothctl info "$mac" 2>/dev/null | awk -F': ' '/Battery Percentage:/ {print $2; exit}' || echo "")
    if [ -n "$bat" ]; then
      tooltip+=$'\n'"  $name ${bat}%"
    else
      tooltip+=$'\n'"  $name"
    fi
  done < <(bluetoothctl devices Connected 2>/dev/null | head -5)
else
  tooltip+=$'\n'"0 connected"
fi

# Bar text = single clean symbol only
if [ "$powered" != "yes" ]; then
  bar_icon="󰂲"
elif [ "$num" -gt 0 ]; then
  bar_icon="󰂱"
else
  bar_icon="󰂯"
fi

jq -cn \
  --arg text "$bar_icon" \
  --arg tooltip "$tooltip" \
  --arg class "on" \
  --argjson percentage 100 \
  '{text:$text, tooltip:$tooltip, class:$class, percentage:$percentage}'
