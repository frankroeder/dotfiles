#!/usr/bin/env bash

set -euo pipefail

status="$("$HOME/.dotfiles/asahi/bin/asahi-waybar-battery")"
tooltip="$(jq -r .tooltip <<< "$status")"

[ -n "$tooltip" ] && [ "$tooltip" != "null" ] || exit 0

"$HOME/.dotfiles/asahi/bin/asahi-walker" --dmenu --placeholder Battery --width 560 --height 360 --exit <<< "$tooltip" >/dev/null || true
