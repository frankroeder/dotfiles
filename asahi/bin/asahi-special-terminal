#!/usr/bin/env bash

set -euo pipefail

terminal="${TERMINAL:-ghostty}"
workspace="special:term"

if hyprctl clients -j | jq -e --arg workspace "$workspace" '.[] | select(.workspace.name == $workspace)' >/dev/null; then
  exec hyprctl dispatch togglespecialworkspace term
fi

if command -v uwsm-app >/dev/null 2>&1; then
  hyprctl dispatch exec "[workspace $workspace silent] uwsm-app -- $terminal"
else
  hyprctl dispatch exec "[workspace $workspace silent] $terminal"
fi
sleep 0.2
hyprctl dispatch togglespecialworkspace term
