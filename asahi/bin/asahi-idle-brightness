#!/usr/bin/env bash

set -euo pipefail

action="${1:-}"
state_dir="${ASAHI_IDLE_STATE_DIR:-${XDG_RUNTIME_DIR:-/tmp}/asahi-idle-brightness}"
screen_shader="${ASAHI_IDLE_DIM_SHADER:-$HOME/.dotfiles/asahi/hypr/shaders/idle-dim.frag}"

usage() {
  echo "usage: $0 <dim|off|restore>" >&2
  exit 2
}

brightness_device() {
  local device="${ASAHI_BACKLIGHT_DEVICE:-apple-panel-bl}"

  if brightnessctl --device="$device" info >/dev/null 2>&1; then
    printf "%s\n" "$device"
    return 0
  fi

  for path in /sys/class/backlight/*; do
    [ -e "$path" ] || continue
    basename "$path"
    return 0
  done

  return 1
}

keyboard_device() {
  local device="${ASAHI_KEYBOARD_BACKLIGHT_DEVICE:-kbd_backlight}"

  if brightnessctl --device="$device" info >/dev/null 2>&1; then
    printf "%s\n" "$device"
    return 0
  fi

  for path in /sys/class/leds/*kbd_backlight*; do
    [ -e "$path" ] || continue
    basename "$path"
    return 0
  done

  return 1
}

save_device() {
  local name="$1"
  local device="$2"
  local state="$state_dir/$name"

  mkdir -p "$state_dir"
  [ -s "$state" ] && return 0
  brightnessctl --device="$device" get > "$state"
}

set_device() {
  local device="$1"
  local value="$2"

  brightnessctl --quiet --device="$device" set "$value" >/dev/null 2>&1 || true
}

restore_device() {
  local name="$1"
  local device="$2"
  local state="$state_dir/$name"
  local value

  [ -s "$state" ] || return 0
  value="$(<"$state")"
  set_device "$device" "$value"
  rm -f "$state"
}

current_screen_shader() {
  local output
  local value

  if ! output="$(hyprctl getoption decoration:screen_shader 2>/dev/null)"; then
    printf "\n"
    return 0
  fi
  value="$output"
  value="${value%%$'\n'*}"
  value="${value#str: }"
  [ "$value" = "[[EMPTY]]" ] && value=""
  [ -n "$value" ] && [ ! -r "$value" ] && value=""
  printf "%s\n" "$value"
}

save_screen_shader() {
  local state="$state_dir/screen_shader"

  mkdir -p "$state_dir"
  [ -e "$state" ] && return 0
  current_screen_shader > "$state"
}

set_screen_shader() {
  local value="$1"

  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  hyprctl eval "hl.config({ decoration = { screen_shader = \"$value\" } })" >/dev/null 2>&1 || true
}

dim_screen_shader() {
  [ -r "$screen_shader" ] || return 0
  save_screen_shader
  set_screen_shader "$screen_shader"
}

restore_screen_shader() {
  local state="$state_dir/screen_shader"
  local value

  [ -e "$state" ] || return 0
  value="$(<"$state")"
  if [ -n "$value" ]; then
    set_screen_shader "$value"
  else
    hyprctl reload config-only >/dev/null 2>&1 || true
  fi
  rm -f "$state"
}

case "$action" in
  dim)
    if device="$(brightness_device)"; then
      save_device display "$device"
      set_device "$device" 10%
    fi

    if device="$(keyboard_device)"; then
      save_device keyboard "$device"
      set_device "$device" 10%
    fi
    dim_screen_shader
    ;;
  off)
    if device="$(brightness_device)"; then
      save_device display "$device"
      set_device "$device" 0
    fi
    if device="$(keyboard_device)"; then
      save_device keyboard "$device"
      set_device "$device" 0
    fi
    ;;
  restore)
    restore_screen_shader
    if device="$(brightness_device)"; then
      restore_device display "$device"
    fi

    if device="$(keyboard_device)"; then
      restore_device keyboard "$device"
    fi
    ;;
  *)
    usage
    ;;
esac
