#!/usr/bin/env bash
#
# asahi-temperature
#
# Lists available temperature sensors using stable hwmon names/labels instead
# of volatile hwmonN indices.
#

set -euo pipefail

best_raw=""
best_name=""
best_label=""
best_path=""

read_value() {
  local path="$1"

  [ -r "$path" ] || return 1
  tr -d '\n' < "$path"
}

sensor_label() {
  local input="$1"
  local sensor="${input##*/}"
  local label

  sensor="${sensor%_input}"
  label="$(read_value "${input%_input}_label" 2>/dev/null || true)"
  printf "%s\n" "${label:-$sensor}"
}

sensor_desc() {
  local name="$1"
  local label="$2"

  case "$name:$label" in
    macsmc_hwmon:NAND\ Flash\ Temperature)
      printf "SMC storage/NAND area sensor."
      ;;
    macsmc_hwmon:Battery\ Hotspot)
      printf "SMC battery-near hotspot; useful chassis heat proxy."
      ;;
    macsmc_hwmon:Charge\ Regulator\ Temp)
      printf "SMC charge/power regulation; often the hottest system sensor."
      ;;
    macsmc_hwmon:WiFi/BT\ Module\ Temp)
      printf "SMC Wi-Fi/Bluetooth module temperature."
      ;;
    macsmc_battery:*)
      printf "Battery pack temperature from the SMC battery driver."
      ;;
    nvme:Composite)
      printf "NVMe SSD controller composite temperature."
      ;;
    tas2764:*)
      printf "Speaker amplifier chip; rises under audio load."
      ;;
  esac
}

print_sensor() {
  local hwmon="$1"
  local input="$2"
  local name label raw celsius desc

  raw="$(read_value "$input" 2>/dev/null || true)"
  case "$raw" in
    '' | *[!0-9-]*) return ;;
  esac

  name="$(read_value "$hwmon/name" 2>/dev/null || printf "unknown")"
  label="$(sensor_label "$input")"
  celsius="$(awk -v value="$raw" 'BEGIN { printf "%.2f", value / 1000 }')"
  desc="$(sensor_desc "$name" "$label")"

  printf "  %-18s %-28s %7s°C   %s\n" "$name" "$label" "$celsius" "$input"
  [ -n "$desc" ] && printf "    %s\n" "$desc"

  if [ -z "$best_raw" ] || [ "$raw" -gt "$best_raw" ]; then
    best_raw="$raw"
    best_name="$name"
    best_label="$label"
    best_path="$input"
  fi
}

echo "============================================"
echo "     Asahi Linux Temperature Sensors"
echo "============================================"
echo ""
echo "Values are read from /sys/class/hwmon by device name and temp label."
echo ""

for hwmon in /sys/class/hwmon/hwmon{0..99}; do
  [ -d "$hwmon" ] || continue

  printed_header=0
  for input in "$hwmon"/temp*_input; do
    [ -r "$input" ] || continue

    if [ "$printed_header" -eq 0 ]; then
      name="$(read_value "$hwmon/name" 2>/dev/null || printf "unknown")"
      printf ">>> %s (%s)\n" "$name" "$hwmon"
      printed_header=1
    fi

    print_sensor "$hwmon" "$input"
  done

  [ "$printed_header" -eq 1 ] && echo ""
done

if [ -n "$best_raw" ]; then
  best_celsius="$(awk -v value="$best_raw" 'BEGIN { printf "%.2f", value / 1000 }')"
  echo "Hottest:"
  printf "  %s / %s: %s°C   %s\n" "$best_name" "$best_label" "$best_celsius" "$best_path"
fi
