#!/usr/bin/env bash

set -euo pipefail

cache="${XDG_CACHE_HOME:-$HOME/.cache}/asahi-theme"
config="$cache/hypr/hyprlock.conf"

"$HOME/.dotfiles/asahi/bin/asahi-theme" auto --no-restart

if [ ! -r "$config" ]; then
  notify-send -a Hyprlock -t 2500 "Hyprlock config missing" "$config"
  exit 1
fi

notify-send -a Hyprlock -t 1500 "Hyprlock config ready" "Hyprlock reads it on next lock"
