#!/usr/bin/env bash

set -euo pipefail

dotfiles="$HOME/.dotfiles"
fuzzel_cmd="fuzzel --dmenu"

choice="$(
  printf '%s\n' \
    "ůįÄĽ Launcher" \
    "ůĪā¨ Terminal scratchpad" \
    "ůįŹó Toggle scratchpad" \
    "ůįćļ Send to scratchpad" \
    "ůį§® Network" \
    "ÔäĒ Bluetooth" \
    "ůįłČ Wallpaper" \
    "ůįĄĄ Screenshot region" \
    "ůįĻĎ Screenshot full" \
    "ůįĎď Reload Hyprland" \
    "ůįĎź Restart Bar (Quickshell)" \
    "ůįĎď Restart Mako" \
    "ůįĎď Restart Hyprpaper" \
    "ůįĎď Restart Hypridle" \
    "ůįĆĺ Lock" \
    "ůįź• Power" |
    $fuzzel_cmd --placeholder Features || true
)"

case "$choice" in
  "ůįÄĽ Launcher")
    exec qs -c remix ipc call launcher toggle
    ;;
  "ůĪā¨ Terminal scratchpad")
    exec "$dotfiles/asahi/bin/asahi-special-terminal"
    ;;
  "ůįŹó Toggle scratchpad")
    hyprctl dispatch togglespecialworkspace scratch
    ;;
  "ůįćļ Send to scratchpad")
    hyprctl dispatch movetoworkspacesilent special:scratch
    ;;
  "ůį§® Network")
    exec "$dotfiles/asahi/bin/asahi-network-menu"
    ;;
  "ÔäĒ Bluetooth")
    exec "$dotfiles/asahi/bin/asahi-bluetooth-menu"
    ;;
  "ůįłČ Wallpaper")
    exec "$dotfiles/asahi/bin/asahi-wallpaper-menu"
    ;;
  "ůįĄĄ Screenshot region")
    exec "$dotfiles/asahi/bin/asahi-cmd-screenshot" region
    ;;
  "ůįĻĎ Screenshot full")
    exec "$dotfiles/asahi/bin/asahi-cmd-screenshot" fullscreen
    ;;
  "ůįĎď Reload Hyprland")
    exec "$dotfiles/asahi/bin/asahi-reload-hyprland"
    ;;
  "ůįĎź Restart Bar (Quickshell)")
    exec "$dotfiles/asahi/bin/asahi-restart-app" quickshell -c remix
    ;;
  "ůįĎď Restart Mako")
    exec "$dotfiles/asahi/bin/asahi-restart-app" mako --config "$HOME/.config/mako/config"
    ;;
  "ůįĎď Restart Hyprpaper")
    exec "$dotfiles/asahi/bin/asahi-restart-app" hyprpaper
    ;;
  "ůįĎď Restart Hypridle")
    exec "$dotfiles/asahi/bin/asahi-restart-app" hypridle
    ;;
  "ůįĆĺ Lock")
    loginctl lock-session
    ;;
  "ůįź• Power")
    exec "$dotfiles/asahi/bin/asahi-control-menu"
    ;;
esac
