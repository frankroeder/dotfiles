#!/usr/bin/env bash

set -euo pipefail

dotfiles="$HOME/.dotfiles"
walker="walker"

choice="$(
  printf '%s\n' \
    "َ°€» Launcher" \
    "َ±‚¬ Terminal scratchpad" \
    "َ°ڈ— Toggle scratchpad" \
    "َ°چ؛ Send to scratchpad" \
    "َ°¤¨ Network" \
    "ïٹ” Bluetooth" \
    "َ°¸‰ Wallpaper" \
    "َ°„„ Screenshot region" \
    "َ°¹‘ Screenshot full" \
    "َ°‘“ Reload Hyprland" \
    "َ°‘گ Restart Waybar" \
    "َ°‘“ Restart Mako" \
    "َ°‘“ Restart Hyprpaper" \
    "َ°‘“ Restart Hypridle" \
    "َ°Œ¾ Lock" \
    "َ°گ¥ Power" |
    "$walker" --dmenu --placeholder Features --width 420 --height 480 --exit || true
)"

case "$choice" in
  "َ°€» Launcher")
    exec "$walker"
    ;;
  "َ±‚¬ Terminal scratchpad")
    exec "$dotfiles/asahi/bin/asahi-special-terminal"
    ;;
  "َ°ڈ— Toggle scratchpad")
    hyprctl dispatch togglespecialworkspace scratch
    ;;
  "َ°چ؛ Send to scratchpad")
    hyprctl dispatch movetoworkspacesilent special:scratch
    ;;
  "َ°¤¨ Network")
    exec "$dotfiles/asahi/bin/asahi-network-menu"
    ;;
  "ïٹ” Bluetooth")
    exec "$dotfiles/asahi/bin/asahi-bluetooth-menu"
    ;;
  "َ°¸‰ Wallpaper")
    exec "$dotfiles/asahi/bin/asahi-wallpaper-menu"
    ;;
  "َ°„„ Screenshot region")
    exec "$dotfiles/asahi/bin/asahi-cmd-screenshot" region
    ;;
  "َ°¹‘ Screenshot full")
    exec "$dotfiles/asahi/bin/asahi-cmd-screenshot" fullscreen
    ;;
  "َ°‘“ Reload Hyprland")
    exec "$dotfiles/asahi/bin/asahi-reload-hyprland"
    ;;
  "َ°‘گ Restart Waybar")
    exec "$dotfiles/asahi/bin/asahi-restart-app" waybar -c "$HOME/.config/waybar/config.jsonc" -s "$HOME/.config/waybar/style.css"
    ;;
  "َ°‘“ Restart Mako")
    exec "$dotfiles/asahi/bin/asahi-restart-app" mako --config "$HOME/.config/mako/config"
    ;;
  "َ°‘“ Restart Hyprpaper")
    exec "$dotfiles/asahi/bin/asahi-restart-app" hyprpaper
    ;;
  "َ°‘“ Restart Hypridle")
    exec "$dotfiles/asahi/bin/asahi-restart-app" hypridle
    ;;
  "َ°Œ¾ Lock")
    loginctl lock-session
    ;;
  "َ°گ¥ Power")
    exec "$dotfiles/asahi/bin/asahi-control-menu"
    ;;
esac
