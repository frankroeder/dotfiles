#!/usr/bin/env bash

set -euo pipefail

dotfiles="${DOTFILES:-$HOME/.dotfiles}"
cache="${XDG_CACHE_HOME:-$HOME/.cache}/asahi-theme"
xdg="$cache/xdg"
wallpapers="${ASAHI_WALLPAPERS_DIR:-$HOME/Pictures/wallpaper}"
mode="${1:-auto}"
requested_mode="$mode"
restart=1

if [ "$mode" = "--no-restart" ]; then
  mode="auto"
  requested_mode="auto"
  restart=0
fi

if [ "${2:-}" = "--no-restart" ]; then
  restart=0
fi

system_mode() {
  local color_scheme gtk_theme

  if ! command -v gsettings >/dev/null 2>&1; then
    printf '%s\n' light
    return
  fi

  color_scheme="$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null || true)"
  gtk_theme="$(gsettings get org.gnome.desktop.interface gtk-theme 2>/dev/null || true)"

  case "$color_scheme" in
    *prefer-dark*)
      printf '%s\n' dark
      ;;
    *prefer-light*)
      printf '%s\n' light
      ;;
    *)
      if [[ "${gtk_theme,,}" == *dark* ]]; then
        printf '%s\n' dark
      else
        printf '%s\n' light
      fi
      ;;
  esac
}

if [ "$mode" = "auto" ]; then
  mode="$(system_mode)"
fi

case "$mode" in
  dark)
    rosewater="f5e0dc"; flamingo="f2cdcd"; pink="f5c2e7"; mauve="cba6f7"; red="f38ba8"; maroon="eba0ac"
    peach="fab387"; yellow="f9e2af"; green="a6e3a1"; teal="94e2d5"; sky="89dceb"; sapphire="74c7ec"
    blue="89b4fa"; lavender="b4befe"; text="cdd6f4"; subtext1="bac2de"; subtext0="a6adc8"
    overlay2="9399b2"; overlay1="7f849c"; overlay0="6c7086"; surface2="585b70"; surface1="45475a"
    surface0="313244"; base="1e1e2e"; mantle="181825"; crust="11111b"
    base_rgb="30, 30, 46"; crust_rgb="17, 17, 27"; text_rgb="205, 214, 244"; blue_rgb="137, 180, 250"
    color_scheme="dark"
    ;;
  light)
    rosewater="dc8a78"; flamingo="dd7878"; pink="ea76cb"; mauve="8839ef"; red="d20f39"; maroon="e64553"
    peach="fe640b"; yellow="df8e1d"; green="40a02b"; teal="179299"; sky="04a5e5"; sapphire="209fb5"
    blue="1e66f5"; lavender="7287fd"; text="4c4f69"; subtext1="5c5f77"; subtext0="6c6f85"
    overlay2="7c7f93"; overlay1="8c8fa1"; overlay0="9ca0b0"; surface2="acb0be"; surface1="bcc0cc"
    surface0="ccd0da"; base="eff1f5"; mantle="e6e9ef"; crust="dce0e8"
    base_rgb="239, 241, 245"; crust_rgb="220, 224, 232"; text_rgb="76, 79, 105"; blue_rgb="30, 102, 245"
    color_scheme="light"
    ;;
  *)
    echo "usage: $0 [auto|dark|light] [--no-restart]" >&2
    exit 2
    ;;
esac

if [ "$requested_mode" != "auto" ] && command -v gsettings >/dev/null 2>&1; then
  if [ "$mode" = "dark" ]; then
    gsettings set org.gnome.desktop.interface color-scheme prefer-dark 2>/dev/null || true
    gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3-dark 2>/dev/null || true
  else
    gsettings set org.gnome.desktop.interface color-scheme prefer-light 2>/dev/null || true
    gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3 2>/dev/null || true
  fi
fi

install -d \
  "$cache/ghostty" \
  "$cache/hypr" \
  "$cache/librewolf" \
  "$cache/mako" \
  "$cache/waybar" \
  "$xdg/walker/themes/asahi" \
  "$xdg/swayosd"

write_gtk_palette() {
  {
    printf '@define-color rosewater #%s;\n' "$rosewater"
    printf '@define-color flamingo #%s;\n' "$flamingo"
    printf '@define-color pink #%s;\n' "$pink"
    printf '@define-color mauve #%s;\n' "$mauve"
    printf '@define-color red #%s;\n' "$red"
    printf '@define-color maroon #%s;\n' "$maroon"
    printf '@define-color peach #%s;\n' "$peach"
    printf '@define-color yellow #%s;\n' "$yellow"
    printf '@define-color green #%s;\n' "$green"
    printf '@define-color teal #%s;\n' "$teal"
    printf '@define-color sky #%s;\n' "$sky"
    printf '@define-color sapphire #%s;\n' "$sapphire"
    printf '@define-color blue #%s;\n' "$blue"
    printf '@define-color lavender #%s;\n' "$lavender"
    printf '@define-color text #%s;\n' "$text"
    printf '@define-color subtext1 #%s;\n' "$subtext1"
    printf '@define-color subtext0 #%s;\n' "$subtext0"
    printf '@define-color overlay2 #%s;\n' "$overlay2"
    printf '@define-color overlay1 #%s;\n' "$overlay1"
    printf '@define-color overlay0 #%s;\n' "$overlay0"
    printf '@define-color surface2 #%s;\n' "$surface2"
    printf '@define-color surface1 #%s;\n' "$surface1"
    printf '@define-color surface0 #%s;\n' "$surface0"
    printf '@define-color base #%s;\n' "$base"
    printf '@define-color mantle #%s;\n' "$mantle"
    printf '@define-color crust #%s;\n\n' "$crust"
  } > "$1"
}

write_librewolf_palette() {
  {
    printf ':root {\n'
    printf '  color-scheme: %s;\n' "$color_scheme"
    printf '  --asahi-color-scheme: %s;\n' "$color_scheme"
    printf '  --ctp-rosewater: #%s;\n' "$rosewater"
    printf '  --ctp-flamingo: #%s;\n' "$flamingo"
    printf '  --ctp-pink: #%s;\n' "$pink"
    printf '  --ctp-mauve: #%s;\n' "$mauve"
    printf '  --ctp-red: #%s;\n' "$red"
    printf '  --ctp-peach: #%s;\n' "$peach"
    printf '  --ctp-yellow: #%s;\n' "$yellow"
    printf '  --ctp-green: #%s;\n' "$green"
    printf '  --ctp-teal: #%s;\n' "$teal"
    printf '  --ctp-sky: #%s;\n' "$sky"
    printf '  --ctp-blue: #%s;\n' "$blue"
    printf '  --ctp-lavender: #%s;\n' "$lavender"
    printf '  --ctp-text: #%s;\n' "$text"
    printf '  --ctp-subtext1: #%s;\n' "$subtext1"
    printf '  --ctp-subtext0: #%s;\n' "$subtext0"
    printf '  --ctp-overlay0: #%s;\n' "$overlay0"
    printf '  --ctp-surface2: #%s;\n' "$surface2"
    printf '  --ctp-surface1: #%s;\n' "$surface1"
    printf '  --ctp-surface0: #%s;\n' "$surface0"
    printf '  --ctp-base: #%s;\n' "$base"
    printf '  --ctp-mantle: #%s;\n' "$mantle"
    printf '  --ctp-crust: #%s;\n' "$crust"
    printf '}\n'
  } > "$cache/librewolf/librewolf.css"
}

link_librewolf_profiles() {
  local profile_dir

  [ -d "$HOME/.config/librewolf/librewolf" ] || return 0

  for profile_dir in "$HOME"/.config/librewolf/librewolf/*.default*; do
    [ -d "$profile_dir" ] || continue

    mkdir -p "$profile_dir/chrome"
    ln -sf "$dotfiles/asahi/librewolf/userChrome.css" "$profile_dir/chrome/userChrome.css"
    ln -sf "$dotfiles/asahi/librewolf/userContent.css" "$profile_dir/chrome/userContent.css"
    ln -sf "$cache/librewolf/librewolf.css" "$profile_dir/chrome/librewolf.css"
    ln -sf "$dotfiles/asahi/librewolf/user.js" "$profile_dir/user.js"
  done
}

ln -sf "$dotfiles/asahi/walker/config.toml" "$xdg/walker/config.toml"
printf '%s\n' "$mode" > "$cache/mode"
write_librewolf_palette
link_librewolf_profiles

if [ "$mode" = "dark" ]; then
  {
    printf '%s\n' "theme = Catppuccin Mocha"
    printf '%s\n' "window-theme = dark"
  } > "$cache/ghostty/config"
else
  {
    printf '%s\n' "theme = Catppuccin Latte"
    printf '%s\n' "window-theme = light"
  } > "$cache/ghostty/config"
fi

write_gtk_palette "$cache/waybar/style.css"
sed '/^@define-color /d' "$dotfiles/asahi/waybar/style.css" >> "$cache/waybar/style.css"

write_gtk_palette "$xdg/walker/themes/asahi/style.css"
sed '/^@define-color /d' "$dotfiles/asahi/walker/themes/asahi/style.css" >> "$xdg/walker/themes/asahi/style.css"

cat > "$cache/mako/config" <<EOF
font=Cascadia Mono NF 10
width=360
height=140
margin=12
padding=12
border-size=2
border-radius=8
background-color=#${base}ee
text-color=#${text}
border-color=#${blue}
progress-color=over #${surface0}
default-timeout=6000
ignore-timeout=0
anchor=top-right
on-notify=exec ${dotfiles}/asahi/bin/asahi-notification-sound

[urgency=high]
border-color=#${red}
default-timeout=0
EOF

cat > "$cache/hypr/hyprlock.conf" <<EOF
background {
  monitor =
  path = ${wallpapers}/rocket_launch.jpg
  color = rgb(${base})
}

input-field {
  monitor =
  outline_thickness = 8
  outer_color = rgb(${blue})
  inner_color = rgb(${surface0})
  font_color = rgb(${text})
  fade_on_empty = false
  position = 0, -80
}

label {
  monitor =
  text = cmd[update:1000] date +'%H:%M'
  color = rgb(${text})
  font_size = 84
  font_family = Cascadia Mono NF
  position = 0, 80
}
EOF

cat > "$xdg/swayosd/style.css" <<EOF
window#osd {
  border: 1px solid rgba(${blue_rgb}, 0.35);
  border-radius: 999px;
  background: rgba(${base_rgb}, 0.94);
  box-shadow: 0 12px 28px rgba(${crust_rgb}, 0.45);
}

window#osd #container {
  margin: 16px;
}

window#osd image,
window#osd label {
  color: #${text};
}

window#osd progressbar:disabled,
window#osd image:disabled {
  opacity: 0.5;
}

window#osd progressbar,
window#osd segmentedprogress {
  min-height: 6px;
  border: none;
  border-radius: 999px;
  background: transparent;
}

window#osd trough,
window#osd segment {
  min-height: inherit;
  border: none;
  border-radius: inherit;
  background: rgba(${text_rgb}, 0.35);
}

window#osd progress,
window#osd segment.active {
  min-height: inherit;
  border: none;
  border-radius: inherit;
  background: #${blue};
}

window#osd segment {
  margin-left: 8px;
}

window#osd segment:first-child {
  margin-left: 0;
}
EOF

stop_app() {
  local app="$1"

  pkill -x "$app" 2>/dev/null || true

  for _ in {1..30}; do
    if ! pgrep -x "$app" >/dev/null 2>&1; then
      return
    fi
    sleep 0.1
  done
}

start_app() {
  command -v "$1" >/dev/null 2>&1 || return 0

  if command -v uwsm-app >/dev/null 2>&1; then
    setsid uwsm-app -- "$@" >/dev/null 2>&1 &
  else
    setsid "$@" >/dev/null 2>&1 &
  fi
}

start_xdg_app() {
  command -v "$1" >/dev/null 2>&1 || return 0

  if command -v uwsm-app >/dev/null 2>&1; then
    XDG_CONFIG_HOME="$xdg" setsid uwsm-app -- "$@" >/dev/null 2>&1 &
  else
    XDG_CONFIG_HOME="$xdg" setsid "$@" >/dev/null 2>&1 &
  fi
}

apply_hypr_theme() {
  command -v hyprctl >/dev/null 2>&1 || return 0

  hyprctl keyword general:col.active_border "rgb(${blue}) rgb(${mauve}) 45deg" >/dev/null 2>&1 || true
  hyprctl keyword general:col.inactive_border "rgb(${surface1})" >/dev/null 2>&1 || true
  hyprctl keyword decoration:shadow:color "rgba(${crust}aa)" >/dev/null 2>&1 || true
}

apply_hypr_theme

if [ "$restart" -eq 1 ]; then
  stop_app waybar
  start_app waybar -c "$dotfiles/asahi/waybar/config.jsonc" -s "$cache/waybar/style.css"

  stop_app mako
  start_app mako --config "$cache/mako/config"

  pkill -SIGUSR2 ghostty 2>/dev/null || true

  systemctl --user restart elephant.service 2>/dev/null || true
  stop_app walker
  start_xdg_app walker --gapplication-service

  stop_app swayosd-server
  start_xdg_app swayosd-server
fi
