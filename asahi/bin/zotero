#!/usr/bin/env bash
#
# Asahi wrapper for Zotero linux-arm64.
# - ulimit + direct zotero-bin (prevents stock launcher forcing WAYLAND=1)
# - X11 + software rendering (required on Asahi/Hyprland)
# - runtime omni.ja guard + auto-patch (arm64 tarball + updates miss white/loading.svg)
# - extra flags to stop GFX compositor crashes + clean Java/LO integration

ulimit -n 4096 2>/dev/null || true

# Self-heal the missing skin asset (causes "Missing chrome.../white/loading.svg" + SEGV).
_omni=/opt/zotero/app/omni.ja
if [[ -f $_omni ]] && ! unzip -l "$_omni" 2>/dev/null | grep -q 'zotero/16/white/loading.svg'; then
  echo "[zotero-wrapper] patching missing white/loading.svg..." >&2
  t=$(mktemp -d)
  mkdir -p "$t/chrome/skin/default/zotero/16/white"
  unzip -p "$_omni" 'chrome/skin/default/zotero/16/light/loading.svg' >"$t/chrome/skin/default/zotero/16/white/loading.svg" 2>/dev/null || true
  if (cd "$t" && zip -r -u "$_omni" chrome/ >/dev/null 2>&1); then
    echo "[zotero-wrapper] patched (no sudo)" >&2
  elif (cd "$t" && sudo zip -r -u "$_omni" chrome/ >/dev/null 2>&1); then
    echo "[zotero-wrapper] patched (sudo)" >&2
  else
    echo "[zotero-wrapper] auto-patch failed; run manually then clear caches:" >&2
    cat >&2 <<'EOM'
  sudo bash -c '
    tmp=$(mktemp -d)
    mkdir -p $tmp/chrome/skin/default/zotero/16/white
    unzip -p /opt/zotero/app/omni.ja chrome/skin/default/zotero/16/light/loading.svg >$tmp/chrome/skin/default/zotero/16/white/loading.svg
    (cd $tmp && sudo zip -r -u /opt/zotero/app/omni.ja chrome/)
    rm -rf $tmp
  '
  rm -f ~/.zotero/zotero/*/compatibility.ini
  rm -rf ~/.zotero/zotero/*/startupCache ~/.cache/zotero
EOM
    rm -rf "$t"
    exit 1
  fi
  rm -rf "$t"
fi

exec env \
  MOZ_ALLOW_DOWNGRADE=1 \
  MOZ_LEGACY_PROFILES=1 \
  GDK_BACKEND=x11 \
  MOZ_ENABLE_WAYLAND=0 \
  MOZ_DISABLE_HWACCEL=1 \
  MOZ_DISABLE_RDD_SANDBOX=1 \
  LIBGL_ALWAYS_SOFTWARE=1 \
  MOZ_WEBRENDER=0 \
  MOZ_DRM_DISABLE=1 \
  JAVA_TOOL_OPTIONS="--enable-native-access=ALL-UNNAMED" \
  GDK_SCALE=2 \
  GDK_DPI_SCALE=2 \
  /opt/zotero/zotero-bin -app /opt/zotero/app/application.ini --disable-gpu "$@"
