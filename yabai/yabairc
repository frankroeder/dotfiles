#!/usr/bin/env bash

# Unload the macOS WindowManager process
launchctl unload -F /System/Library/LaunchAgents/com.apple.WindowManager.plist > /dev/null 2>&1 &

yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

bar_height() {
  local cmd="$1"
  local fallback="$2"
  local height=""

  if command -v "$cmd" >/dev/null 2>&1; then
    height=$("$cmd" --query bar 2>/dev/null | jq -r '.height // empty' 2>/dev/null)
  fi

  if [[ $height =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$height"
  else
    printf '%s\n' "$fallback"
  fi
}

TOP_BAR_HEIGHT=$(bar_height sketchybar-top 43)
BOTTOM_BAR_HEIGHT=$(bar_height sketchybar 43)

# Reserve top space for the appswitcher pill (idle height + downward offset),
# reading the geometry from settings.lua so it stays in sync with the pill.
SETTINGS="${DOTFILES:-$HOME/.dotfiles}/sketchybar/settings.lua"
island_num() {
  local value
  value=$(grep -m1 -E "^[[:space:]]*$1[[:space:]]*=" "$SETTINGS" 2>/dev/null | grep -oE '\-?[0-9]+')
  [[ $value =~ ^-?[0-9]+$ ]] && printf '%s\n' "$value" || printf '%s\n' "$2"
}

ISLAND_TOP=$(( $(island_num idle_height 56) + $(island_num y_offset_expand -16) ))
TOP_RESERVE=$TOP_BAR_HEIGHT
[[ $ISLAND_TOP -gt $TOP_RESERVE ]] && TOP_RESERVE=$ISLAND_TOP

yabai -m config window_origin_display        default \
                window_placement             second_child \
                window_shadow                off \
                window_opacity               on \
                window_opacity_duration      0.15 \
                window_insertion_point       focused \
                normal_window_opacity        0.94 \
                active_window_opacity        1.0 \
                window_gap                   20 \
                window_animation_duration    0.2 \
                window_animation_easing      ease_out_circ \
                top_padding                  12 \
                bottom_padding               10 \
                left_padding                 14 \
                right_padding                14 \
                window_zoom_persist          off \
                insert_feedback_color        0xfff38ba8 \
                mouse_follows_focus          off \
                focus_follows_mouse          off \
                mouse_modifier               fn \
                mouse_action1                move \
                mouse_action2                resize \
                mouse_drop_action            swap \
                auto_balance                 off \
                split_ratio                  0.50 \
                split_type                   auto \
                layout                       stack \
                external_bar                 all:${TOP_RESERVE}:${BOTTOM_BAR_HEIGHT}

# events
yabai -m signal --add event=window_created action="sketchybar -m --trigger window_created &> /dev/null; sketchybar-top -m --trigger window_created &> /dev/null"
yabai -m signal --add event=window_destroyed action="sketchybar -m --trigger window_destroyed &> /dev/null; sketchybar-top -m --trigger window_destroyed &> /dev/null"
yabai -m signal --add event=window_moved action="sketchybar-top -m --trigger window_moved &> /dev/null; sketchybar-top -m --trigger space_windows_refresh &> /dev/null"
yabai -m signal --add event=window_minimized action="sketchybar-top -m --trigger window_minimized &> /dev/null"
yabai -m signal --add event=window_deminimized action="sketchybar-top -m --trigger window_deminimized &> /dev/null"
yabai -m signal --add event=window_focused action="sketchybar -m --trigger window_focus &> /dev/null; sketchybar-top -m --trigger window_focus &> /dev/null; sketchybar-island -m --trigger window_focus &> /dev/null"
yabai -m signal --add event=space_changed action="sketchybar-top -m --trigger layout_change &> /dev/null; sketchybar-top -m --trigger space_windows_refresh &> /dev/null"
yabai -m signal --add event=space_created action="sketchybar-top -m --trigger space_created &> /dev/null; sketchybar-top -m --trigger layout_change &> /dev/null"
yabai -m signal --add event=space_destroyed action="sketchybar-top -m --trigger space_destroyed &> /dev/null; sketchybar-top -m --trigger layout_change &> /dev/null"
yabai -m signal --add event=display_removed action="sketchybar-top -m --trigger display_change &> /dev/null; sketchybar-island -m --trigger display_change &> /dev/null; sketchybar-top -m --trigger layout_change &> /dev/null; /bin/sh $HOME/.config/yabai/arrange-displays.sh &"
yabai -m signal --add event=display_added action="sketchybar-top -m --trigger display_change &> /dev/null; sketchybar-island -m --trigger display_change &> /dev/null; sketchybar-top -m --trigger layout_change &> /dev/null; /bin/sh $HOME/.config/yabai/arrange-displays.sh &"
# yabai -m signal --add event=space_changed action="yabai -m window --focus first"

WINDOW_RULES="${DOTFILES:-$HOME/.dotfiles}/yabai/window_rules"
if [[ -f $WINDOW_RULES ]]; then
  source $WINDOW_RULES
fi

yabai -m rule --apply

/bin/sh "$HOME/.config/yabai/arrange-displays.sh" &

"$HOME/.config/borders/bordersrc" >/dev/null 2>&1 &

echo "yabai configuration loaded..."
